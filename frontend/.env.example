# NEXUS AI - Frontend Environment Variables
#
# VITE_API_URL — URL of the FastAPI backend (must include /api suffix).
#
# Examples:
#   - Local dev (Vite proxy):    /api
#   - Render deployment:         https://nexus-ai-backend.onrender.com/api
#   - Railway deployment:        https://nexus-ai-backend.up.railway.app/api
#
# If left empty or the backend is unreachable, the app gracefully falls back
# to built-in demo data so the UI still works on Vercel without a backend.

VITE_API_URL=/api
